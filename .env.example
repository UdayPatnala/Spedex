# ── Spedex Environment Configuration ──

# JWT Secret Key (must be at least 256 bits / 32 characters for HMAC-SHA256)
JWT_SECRET=your_secure_256_bit_jwt_secret_key_here

# Server Port
SERVER_PORT=8080

# Database Configuration (H2 / PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:h2:file:/tmp/spedex_db;DB_CLOSE_ON_EXIT=FALSE;AUTO_RECONNECT=TRUE
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# CORS Allowed Origins (Comma-separated)
SPEDEX_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://spedex.vercel.app
