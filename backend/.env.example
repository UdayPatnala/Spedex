# Database — defaults to SQLite for local dev.
# For production, use a PostgreSQL connection string (e.g. Neon, Supabase, Railway).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/spedex

# JWT signing key — MUST be changed before deploying to production.
# Generate one with: openssl rand -hex 32
SPEDEX_SECRET_KEY=change-me

# Token lifetime in minutes (default: 1440 = 24 hours)
SPEDEX_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of allowed CORS origins.
# Add your deployed frontend URL here for production.
SPEDEX_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081,exp://127.0.0.1:19000

# Set to "true" to seed a demo user (alex@spedex.app / spedex123) on first startup.
# Enable for local dev or staging — leave unset or "false" for production.
SPEDEX_SEED_DEMO=true
